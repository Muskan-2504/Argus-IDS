# Copy this file to `.env` and adjust. Never commit the real `.env`.

APP_NAME=Argus IDS
ENVIRONMENT=development
DEBUG=true

# Security — generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256

# Database / cache
DATABASE_URL=postgresql+psycopg://argus:argus@localhost:5432/argus
REDIS_URL=redis://localhost:6379/0

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173"]

# Optional enrichment integrations (all graceful — fields stay null if unset)
ABUSEIPDB_API_KEY=
GEOIP_DB_PATH=              # path to a MaxMind GeoLite2-City .mmdb (needs the [geoip] extra)
GEOIP_USE_IPAPI=false      # free, key-less geo via ip-api.com (set true to populate the map)
